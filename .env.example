# OpenAI API key, get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Server port (optional, defaults to 3000)
PORT=3000

# ChromaDB connection (optional, defaults to http://localhost:8000)
CHROMA_URL=http://localhost:8000

# Models (optional)
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ChromaDB collection name (optional, defaults to support-docs)
CHROMA_COLLECTION=support-docs

# Chunking + retrieval (optional)
CHUNK_TOKENS=500
CHUNK_OVERLAP=50
TOP_K=4
